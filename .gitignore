# ─── ビルド成果物 ──────────────────────────────────────────────────────────────
# build/ : PyInstaller 中間生成物
# dist/  : exe・設定・token・logs・secrets など全ランタイム生成物の基準ディレクトリ
#          (RYouTubeLiveTools 共通ルール: Python/exe どちらの実行でも dist/ が基準)
build/
dist/

# ─── Python 一般 ──────────────────────────────────────────────────────────────
*.manifest
__pycache__/
*.py[cod]
*.pyd
.Python
*.egg-info/
.eggs/
venv/
.venv/
env/
ENV/

# ─── メディア・アーカイブ ─────────────────────────────────────────────────────
*.zip
*.mp4
*.mkv
*.avi

# ─── IDE・OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
Thumbs.db
Desktop.ini
ehthumbs.db

# ─── プロジェクト固有 ─────────────────────────────────────────────────────────
.claude/
Document/

# ─── ランタイム生成物 安全網 ──────────────────────────────────────────────────
# dist/ 除外で通常はカバーされるが、万一ソースルート直下に出た場合の保護として残す
*_settings.json
RCommentHub/logs/

# ─── 機密ファイル 安全網 ──────────────────────────────────────────────────────
# dist/ 除外で通常はカバーされるが、絶対に追跡させないための二重保護
token.json
client_secrets.json
client_secret_*.json
